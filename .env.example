# ── GitHub Secrets（在 repo Settings > Secrets and variables > Actions 填入）──

# Anthropic API Key（claude.ai 帳號 > API Keys）
ANTHROPIC_API_KEY=sk-ant-...

# 你的 LINE User ID（在 LINE Developers Console 可查到，格式 U + 32碼英數）
OWNER_LINE_USER_ID=U...

# n8n Webhook URL（n8n 收到 GitHub 回傳結果後，推回 LINE 的 webhook）
N8N_WEBHOOK_URL=https://your-n8n.railway.app/webhook/...

# ── 可選：如果要支援 Gemini 路由（省 token 用）──
GEMINI_API_KEY=...
