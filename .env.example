# GitHub Secrets (set in repo Settings > Secrets and variables > Actions)

# Anthropic API key (claude.ai account > API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Your LINE user ID (from LINE Developers Console, format: U + 32 chars)
OWNER_LINE_USER_ID=U...

# Owner Telegram user ID (numeric string)
OWNER_TELEGRAM_USER_ID=123456789

# Allowed LINE user IDs (comma-separated, no spaces)
# Example: Uaaaa...,Ubbbb...,Ucccc...
ALLOWED_LINE_USER_IDS=U...

# n8n webhook URL (receives GitHub callback and pushes response)
N8N_WEBHOOK_URL=https://your-n8n.railway.app/webhook/...

# Shared secret for GitHub → n8n callback authentication (any random string)
# Must match the Header Auth credential set on Workflow B's webhook node (header: X-Brain-Token)
N8N_WEBHOOK_SECRET=
