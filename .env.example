# ── GitHub Actions Secrets ────────────────────────────────────────────────────
# Set these in: repo Settings > Secrets and variables > Actions

# Anthropic API key (claude.ai account > API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Your LINE user ID (from LINE Developers Console, format: U + 32 chars)
OWNER_LINE_USER_ID=U...

# Owner Telegram user ID (numeric string, optional)
OWNER_TELEGRAM_USER_ID=123456789

# Allowed LINE user IDs (comma-separated, no spaces)
# Example: Uaaaa...,Ubbbb...,Ucccc...
ALLOWED_LINE_USER_IDS=U...

# n8n webhook URL that receives the GitHub Actions callback
N8N_WEBHOOK_URL=https://your-n8n.railway.app/webhook/...

# Shared secret for GitHub → n8n authentication (header: X-Brain-Token)
N8N_WEBHOOK_SECRET=


# ── n8n / Railway Environment Variables ──────────────────────────────────────
# Set these in: Railway service > Variables tab (or your n8n host's env config)

# LINE channel secret — required for X-Line-Signature verification
LINE_CHANNEL_SECRET=

# Allow Node's built-in crypto module in n8n Code nodes
NODE_FUNCTION_ALLOW_BUILTIN=crypto
